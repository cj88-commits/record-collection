<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground — vinyl record only, no background fill.
    Viewport: 108×108dp  |  Center: (54, 54)
    Safe zone: 72×72dp (radius ≤ 36 from center)
    Record radius: 40  (~74 % of the 108dp tile — sits inside squircle with padding)
    Label radius:  11  (~27 % of record)
    Hole  radius:   1.4 (~13 % of label)
    Path formula: M (54-r),54  a r,r 0 1,0 (2r),0  a r,r 0 1,0 -(2r),0  Z
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Vinyl disc base: near-black blue-black, r=40 ── -->
    <path
        android:fillColor="#0D0D1A"
        android:pathData="M14,54 a40,40 0 1,0 80,0 a40,40 0 1,0 -80,0 Z"/>

    <!-- ── Groove rings: 12 concentric strokes, alternating #222233 / #161622 ── -->
    <!-- r=37 --> <path android:fillColor="#00000000" android:strokeColor="#222233" android:strokeWidth="0.6"  android:pathData="M17,54 a37,37 0 1,0 74,0 a37,37 0 1,0 -74,0 Z"/>
    <!-- r=35 --> <path android:fillColor="#00000000" android:strokeColor="#161622" android:strokeWidth="0.5"  android:pathData="M19,54 a35,35 0 1,0 70,0 a35,35 0 1,0 -70,0 Z"/>
    <!-- r=33 --> <path android:fillColor="#00000000" android:strokeColor="#222233" android:strokeWidth="0.5"  android:pathData="M21,54 a33,33 0 1,0 66,0 a33,33 0 1,0 -66,0 Z"/>
